{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AegisScore": ""
  },
  "Jwt": {
    "Issuer": "aegis-score",
    "Audience": "aegis-score",
    "SigningKey": "",
    "AccessTokenMinutes": 10,
    "RefreshTokenDays": 7
  },
  "Ai": {
    "Provider": "anthropic",
    "ApiKey": "",
    "Model": "claude-sonnet-5",
    "BaseUrl": "https://api.anthropic.com/v1/messages",
    "AnthropicVersion": "2023-06-01",
    "MaxTokens": 2000
  },
  "AegisAi": {
    "ApiKey": "",
    "Model": "gemini-flash-latest"
  },
  "Scoring": {
    "DefaultSignalFreshnessHours": 72
  },
  "DataProtection": {
    "PersistenceProvider": "DbContext",
    "RequirePersistence": false,
    "RequireKeyEncryption": false
  }
}
